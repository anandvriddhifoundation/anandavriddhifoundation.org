{
  "name": "tellme_videohub_frontend",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_ENV=production next build",
    "start": "cross-env NODE_ENV=production next start",
    "export": "next build && next export",
    "lint": "next lint",
    "shadcn-ui@latest": "shadcn-ui@latest",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "all": "yarn install && yarn upgrade && yarn build",
    "postinstall": "node ./postinstall.mjs",
    "generate-client": "openapi --input http://localhost:8000/openapi.json --output ./src/client --client fetch --name Backend",
    "generate-client-with-options": "openapi --input http://localhost:8000/openapi.json --output ./src/client --client fetch --name Backend --useOptions",
    "openapi-ts": "openapi-ts"
  },
  "author": "Shrikant Dhayaje <shrikantdhayaje@gmail.com> (http://github.com/shriekdj/)",
  "prettier": {
    "arrowParens": "always",
    "semi": true,
    "trailingComma": "all",
    "singleQuote": true
  },
  "dependencies": {
    "@headlessui/react": "1.7.19",
    "@headlessui/tailwindcss": "0.2.0",
    "@hey-api/openapi-ts": "^0.45.1",
    "@next/third-parties": "14.2.3",
    "@nextui-org/react": "2.3.6",
    "@radix-ui/react-accordion": "1.1.2",
    "@radix-ui/react-dialog": "1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-icons": "1.3.0",
    "@radix-ui/react-scroll-area": "1.0.5",
    "@radix-ui/react-slot": "1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@sindresorhus/slugify": "^2.2.1",
    "@tailwindcss/forms": "0.5.7",
    "@tailwindcss/typography": "0.5.12",
    "@tinymce/tinymce-react": "^5.1.1",
    "@types/node": "20.12.7",
    "@types/react": "18.3.0",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "cors": "2.8.5",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.13",
    "embla-carousel-auto-height": "8.0.2",
    "embla-carousel-autoplay": "^8.1.4",
    "embla-carousel-react": "8.0.2",
    "eslint": "8.57.0",
    "eslint-config-next": "14.1.0",
    "express": "4.19.2",
    "flowbite": "2.3.0",
    "flowbite-react": "0.9.0",
    "framer-motion": "11.1.7",
    "fs-extra": "^11.2.0",
    "lodash": "4.17.21",
    "lucide-react": "^1.7.0",
    "net": "1.0.2",
    "next": "^14.2.3",
    "next-auth": "^4.24.7",
    "openapi-typescript-codegen": "0.27.0",
    "postcss": "8.4.38",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "7.51.3",
    "react-icons": "5.0.1",
    "react-player": "^2.16.0",
    "react-youtube": "10.1.0",
    "sharp": "0.33.3",
    "tailwind-merge": "2.3.0",
    "tailwindcss": "3.4.3",
    "tailwindcss-animate": "1.0.7",
    "tailwindcss-react-aria-components": "1.1.1",
    "tinymce": "^7",
    "tls": "0.0.1",
    "typescript": "^5.4.5",
    "vaul": "0.9.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "packageManager": "yarn@1.22.19+sha1.4ba7fc5c6e704fce2066ecbfb0b0d8976fe62447"
}
